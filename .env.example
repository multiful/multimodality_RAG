# 로컬 전용이면 비워둬도 동작한다(Supabase 미설정 시 로컬 JSONL이 원본).
# Ollama (기본값이면 생략 가능)
OLLAMA_URL=http://localhost:11434
QWEN_VL_MODEL=qwen3-vl:8b
QWEN_LLM_MODEL=qwen3:8b
# 프롬프트 버전 (올리면 VLM 캐시 전량 미스 → 재판정)
PROMPT_VER=v2
# MinerU 실행파일 경로를 직접 지정할 때만 (미지정 시 pdfex\demo_venv 자동 탐색)
# MINERU_EXE=C:\path\to\mineru.exe
# 선택: Supabase 저장을 켤 때만
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
