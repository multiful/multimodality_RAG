OPENAI_API_KEY=

# 네이버 검색 API(뉴스, Layer3 뉴스 선정)에 필요.
# https://developers.naver.com/apps/#/register 에서 애플리케이션 등록 후 발급.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# KOSPI200 구성종목 조회(data_collection/kospi200_tickers.py)에 필요.
# data.krx.co.kr 회원가입 후 로그인 계정 정보를 입력.
KRX_ID=
KRX_PW=

# Supabase 프로젝트 설정(Project Settings > API)에서 확인.
# SUPABASE_SERVICE_KEY는 service_role 키(서버 전용, RLS 우회). 절대 클라이언트에 노출하지 말 것.
# 멀티모달 파이프라인(pipeline/)은 미설정 시 로컬 JSONL을 원본으로 사용하므로 비워둬도 동작한다.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# [필수] Supabase 직접 Postgres 연결 문자열(Project Settings > Database > Connection string).
# PDF 업로드/하이브리드 검색/뉴스 감성/배당·Layer 시그널 경로가 전부 이 변수에 게이팅되며,
# 없으면 streamlit 업로드와 run_investment_opinion_demo가 RuntimeError로 중단된다.
SUPABASE_DIRECT_DB_URL=
SUPABASE_PASSWORD=

# OpenDART API 키 — 배당 스코어링 원천 데이터 수집 배치에 필요. https://opendart.fss.or.kr 발급.
OPENDART_API_KEY=

# --- 멀티모달 파이프라인 (pipeline/) ---
# Ollama (기본값이면 생략 가능)
OLLAMA_URL=http://localhost:11434
QWEN_VL_MODEL=qwen3-vl:8b
QWEN_LLM_MODEL=qwen3:8b
# 프롬프트 버전 (올리면 VLM 캐시 전량 미스 → 재판정)
PROMPT_VER=v2
# MinerU 실행파일 경로를 직접 지정할 때만 (미지정 시 pdfex\demo_venv 자동 탐색)
# MINERU_EXE=C:\path\to\mineru.exe
